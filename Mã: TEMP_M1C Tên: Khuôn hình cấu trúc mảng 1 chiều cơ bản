#include <bits/stdc++.h>
using namespace std;
const int huy = 420;    

template <class T>
struct M1C {
    int n;
    T a[huy];

    void nhap() {
        n = 0;
        while (cin >> a[n])
            n++;
    }

    void xuat() {
        for (int i = 0; i < n; i++)
            cout << a[i];
    }

    int tong() {          // đổi void -> int
        int s = 0;
        for (int i = 0; i < n; i++)
            s += a[i];
        return s;         // return thay vì cout
    }
};

int main() {
    M1C<int> t;
    t.nhap();
    cout << t.tong();    // in kết quả ở main
    return 0;
}
