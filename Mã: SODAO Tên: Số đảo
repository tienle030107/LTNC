#include <bits/stdc++.h>
using namespace std;
struct SoDao {
    int n;
    int sodao() {
        int tmp = n, res = 0;
        while (tmp > 0) {
            res = res * 10 + tmp % 10;
            tmp /= 10;
        }
        return res;
    }
};
istream& operator >> (istream &in, SoDao &p) {
    in >> p.n;
    return in;
}
ostream& operator << (ostream &out, SoDao p) {
    out << "[SoDao] " << p.n;
    return out;
}

bool operator > (SoDao a, SoDao b) {
    return a.sodao() > b.sodao();
}

int operator + (SoDao p, int x) {
    return p.sodao() + x;
}
int main() {
    SoDao a, b;
    cin >> a >> b;
    cout << a <<endl;
    cout << b <<endl;
    if (a > b)
        cout << "YES" <<endl;
    else
        cout << "NO" <<endl;
    cout << (b + (a + 0)) <<endl;
    return 0;
}
