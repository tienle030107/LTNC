#include <bits/stdc++.h>
using namespace std;
struct SoMoi
{
    int a;
    int tong()
    {
        int tmp = a, res = 0;
        while (tmp > 0)
        {
            res += tmp % 10;
            tmp /= 10;
        }
        return res;
    }
    bool operator > (SoMoi x)
    {
        return tong() > x.tong();
    }
    SoMoi operator + (SoMoi x)
    {
        SoMoi r;
        r.a = tong() + x.tong();
        return r;
    }
};
istream& operator >> (istream &in, SoMoi &x)
{
    in >> x.a;
    return in;
}
ostream& operator << (ostream &out, SoMoi x)
{
    out << "[SoMoi] " << x.a;
    return out;
}
int main()
{
    SoMoi s1, s2;
    cin >> s1 >> s2;
    cout << s1 <<endl;
    cout << s2 <<endl;
    if (s1 > s2)
        cout << "true" <<endl;
    else
        cout << "false" <<endl;
    cout << s1 + s2 <<endl;
    return 0;
}
