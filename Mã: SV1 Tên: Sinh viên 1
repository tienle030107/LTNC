#include <iostream>
using namespace std;

struct SV {
    string hoTen;
    double diem[3];

    double trungBinh() {
        return (diem[0] + diem[1] + diem[2]) / 3.0;
    }
};

istream& operator>>(istream& in, SV& sv) {
    getline(in, sv.hoTen);
    in >> sv.diem[0] >> sv.diem[1] >> sv.diem[2];
    return in;
}

ostream& operator<<(ostream& out, SV sv) {
    out << sv.hoTen;
    return out;
}

bool operator<(SV a, SV b) {
    return a.trungBinh() < b.trungBinh();
}

int main() {
    int n = 0;
    SV ds[100];

    while (cin >> ds[n]) {
        n++;
        cin.ignore();
    }

    // Tìm SV có TB cao nhất (lấy người đầu tiên nếu bằng nhau)
    int viTriMax = 0;
    for (int i = 1; i < n; i++)
        if (ds[viTriMax] < ds[i])
            viTriMax = i;

    cout << ds[viTriMax];
    return 0;
}
