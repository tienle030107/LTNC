#include <bits/stdc++.h>
using namespace std;
const float PI = 3.14;
struct DIEM
{
    int x, y;
    bool operator == (DIEM d) { return x==d.x && y==d.y; }
    float operator - (DIEM d)
    {
        return sqrt((float)(x-d.x)*(x-d.x) + (float)(y-d.y)*(y-d.y));
    }
};
istream& operator >> (istream &in, DIEM &d)
{
    in >> d.x >> d.y;
    return in;
}
ostream& operator << (ostream &out, DIEM d)
{
    out << "(" << d.x << "," << d.y << ")";
    return out;
}
struct DTRON
{
    DIEM tam;
    int r;
    float cv() { return 2 * PI * r; }
    float dt() { return PI * r * r; }
    bool operator == (DTRON x) { return cv() == x.cv(); }
    bool operator < (DTRON x)  { return cv() < x.cv(); }
    DTRON operator + (DTRON x)
    {
        DTRON res;
        res.tam = {0, 0};
        res.r = 0;
        return res;
    }
    string viTri(DTRON x)
    {
        float oo = tam - x.tam;
        float R = r, R2 = x.r;
        float sumR = R + R2;
        float difR = abs(R - R2);
        oo = roundf(oo * 1000) / 1000;

        if (oo == 0)                            
            return "DT";
        if (oo == roundf(difR*1000)/1000)       
            return "TXT";
        if (oo == roundf(sumR*1000)/1000)       
            return "TXN";
        if (oo < sumR && oo > difR)             
            return "C";
        if (oo > sumR)                          
            return "NN";
        if (oo < difR)                          
            return "DN";
                return "NN";
    }
};
istream& operator >> (istream &in, DTRON &x)
{
    in >> x.tam >> x.r;
    return in;
}
ostream& operator << (ostream &out, DTRON x)
{
    out << x.tam << " " << x.r;
    return out;
}
int main()
{
    DTRON d1, d2;
    cin >> d1 >> d2;
    cout << d1 <<endl;
    cout << d2 <<endl;
    float tong = d1.dt() + d2.dt();
    tong = roundf(tong * 1000) / 1000;
    cout << tong <<endl;
    if (d1 == d2)      cout << "1 = 2" <<endl;
    else if (d1 < d2)  cout << "1 < 2" <<endl;
    else               cout << "1 > 2" <<endl;
    cout << d1.viTri(d2) <<endl;
    return 0;
}
