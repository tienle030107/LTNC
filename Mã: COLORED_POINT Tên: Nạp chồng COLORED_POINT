#include <bits/stdc++.h>
using namespace std;
struct CP
{
    int x, y;
    char mau[7];
};
istream& operator >> (istream &in, CP &p)
{
    in >> p.x >> p.y >> p.mau;
    return in;
}
ostream& operator << (ostream &out, CP p)
{
    out << "(" << p.x << "," << p.y << ",#" << p.mau << ")";
    return out;
}
int main()
{
    int n;
    cin >> n;
    CP *a = new CP[n];
    for (int i = 0; i < n; i++)
        cin >> a[i];
    for (int i = 0; i < n; i++)
    {
        if (i > 0) cout <<endl;
        cout << a[i];
    }
    cout <<endl;
    int dem = 0;
    for (int i = 0; i < n; i++)
        if (strcmp(a[i].mau, "5DC3A8") == 0)
            dem++;
    cout << dem <<endl;
    for (int i = 0; i < n; i++)
        if (a[i].x > a[i].y)
            strcpy(a[i].mau, "1F00F3");
    for (int i = 0; i < n; i++)
    {
        if (i > 0) cout << " ";
        cout << a[i];
    }
    cout <<endl;
    delete[] a;
    return 0;
}
